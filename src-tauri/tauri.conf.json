{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/tooling/cli/schema.json",
  "productName": "OrangeNote",
  "version": "1.0.8",
  "identifier": "com.orange-note.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "橙记 - 一目了然，橙就高效",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHVwZGF0ZSBrZXkKUlVRakUvMjJrQnI5MElEUXFEcU9KQ0Z6MjI5L2RkNG5qYVdWNGRrQ0p5c0t4c0hBaW1VZ0E9PQo=",
      "endpoints": [
        "https://github.com/MarkHoo/OrangeNote/releases/latest/download/latest.json"
      ]
    }
  }
}
